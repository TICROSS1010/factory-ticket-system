{
  "name": "Factory Ticket System",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "jdkDistro": "amzn",
      "installMaven": true
    },
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "postCreateCommand": "chmod +x mvnw && ./mvnw dependency:resolve && docker compose up -d",
  "forwardPorts": [8080, 8000]
}